rules_version = '2';

// Nodtry Cloud Storage security rules.
// Profile images live under users/{uid}/. Anyone signed in may read (partners
// render each other's avatars); only the owner may upload, and uploads are
// constrained to reasonably-sized images.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    // Everything else is denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
